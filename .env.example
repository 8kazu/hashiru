# Notion連携設定 — このファイルを .env にコピーして値を埋める
# トークン: https://www.notion.so/my-integrations で内部インテグレーションを作成
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 親ページ: レポートの新規ページをここの子として作成します（URLをそのまま貼ってOK）
# 注意: そのページの「コネクト」からインテグレーションを接続しておくこと
NOTION_PAGE_ID=https://www.notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
